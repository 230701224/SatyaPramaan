# ─── SatyaPramaan Environment Configuration ────────────────────────────────────
# Copy this file to .env and fill in your credentials.
# The backend reads this via python-dotenv at startup.

# ── Layer 4: Claude AI (Required for real LLM insights) ─────────────────────────
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ── Layer 1: AWS Textract (Optional - falls back to pdfplumber if absent) ────────
# Create IAM user with AmazonTextractFullAccess policy
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-south-1

# ── Layer 1: NSDL PAN Verification (Optional - falls back to mock) ───────────────
# Apply at: https://apiportal.nsdl.com/
NSDL_API_KEY=
NSDL_CLIENT_ID=

# ── Layer 1: MCA21 Company Registry (Optional - falls back to mock) ──────────────
# Apply at: https://www.mca.gov.in/content/mca/global/en/data-and-reports/mca-services/mca21.html
MCA21_API_KEY=

# ── Layer 1: DigiLocker (Optional - requires OAuth2 user consent flow) ───────────
# Register app at: https://developers.digitallocker.gov.in/
DIGILOCKER_ACCESS_TOKEN=

# ── General Settings ─────────────────────────────────────────────────────────────
# Set to "true" to enable real API calls for NSDL/MCA21/DigiLocker
REAL_API_MODE=false

# Set to "false" to disable YOLOv8 seal detection (saves startup time)
ENABLE_SEAL_DETECTION=true

# JWT secret for session tokens (change in production)
JWT_SECRET=satya_pramaan_ai_secret_key_2026
